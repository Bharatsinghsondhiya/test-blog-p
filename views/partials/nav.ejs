<style>
  /* Glassmorphic Navbar */
  .custom-nav {
    background: rgba(15, 23, 42, 0.7);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    padding: 15px 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    box-shadow: 0 4px 30px rgba(0, 0, 0, 0.1);
    position: sticky;
    top: 0;
    z-index: 1000;
  }

  /* White icon for the toggler */
  .navbar-toggler-icon {
    filter: brightness(50);
  }
  
  .navbar-brand {
    font-size: 1.5rem;
    letter-spacing: -0.02em;
    background: linear-gradient(90deg, #f8fafc, var(--secondary-color));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  /* Clean nav links */
  .custom-link {
    color: var(--text-muted) !important; 
    font-weight: 500;
    padding: 8px 16px;
    border-radius: 8px;
    transition: all 0.3s ease;
    letter-spacing: 0.02em;
  }

  .custom-link:hover {
    background: rgba(255, 255, 255, 0.1);
    color: var(--text-main) !important;
  }

  .custom-link.active {
    background: rgba(219, 39, 119, 0.15);
    color: var(--text-main) !important;
    border: 1px solid rgba(219, 39, 119, 0.3);
  }

  /* Add Blog button */
  .custom-add-btn {
    border: 1px solid var(--secondary-color) !important;
    background: rgba(219, 39, 119, 0.1) !important;
    color: var(--text-main) !important;
    font-weight: 600;
    padding: 8px 18px;
    border-radius: 10px;
    transition: all 0.3s ease;
    text-decoration: none;
  }
  .custom-add-btn:hover {
    background: linear-gradient(135deg, var(--primary-color), var(--secondary-color)) !important;
    border-color: transparent !important;
    transform: translateY(-2px);
    box-shadow: 0 4px 15px rgba(219, 39, 119, 0.3);
  }

  /* Avatar */
  .user-avatar {
    width: 38px;
    height: 38px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid var(--secondary-color);
    box-shadow: 0 0 10px rgba(219, 39, 119, 0.3);
  }

  /* Dropdown styling */
  .custom-dropdown {
    background: rgba(15, 23, 42, 0.9);
    backdrop-filter: blur(16px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
    border-radius: 12px;
    padding: 0.5rem;
    margin-top: 10px;
  }

  .custom-dropdown .dropdown-item {
    color: var(--text-muted) !important;
    border-radius: 8px;
    transition: all 0.2s;
    padding: 8px 16px;
  }

  .custom-dropdown .dropdown-item:hover {
    background: rgba(255, 255, 255, 0.1) !important;
    color: var(--text-main) !important;
  }

  .custom-dropdown .dropdown-divider {
    border-color: rgba(255, 255, 255, 0.1);
  }
</style>

<nav class="navbar navbar-expand-lg custom-nav" data-bs-theme="dark">
  <div class="container-fluid">

    <a class="navbar-brand fw-bold text-white" href="/">Blogify</a>

    <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
      data-bs-target="#navbarNavDropdown" aria-controls="navbarNavDropdown"
      aria-expanded="false" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="navbarNavDropdown">

      <!-- Left links -->
      <ul class="navbar-nav me-auto mb-2 mb-lg-0">
        <li class="nav-item">
          <a class="nav-link custom-link active" href="/">Home</a>
        </li>
      </ul>

      <!-- Right side -->
      <ul class="navbar-nav ms-auto align-items-center">

        <% if (locals.user) { %>

          <li class="nav-item me-2">
            <a class="custom-add-btn" href="/blog/add-new">Add Blog</a>
          </li>

          <li class="nav-item dropdown">
            <a class="nav-link custom-link dropdown-toggle d-flex align-items-center"
               href="#" id="userMenu" role="button" data-bs-toggle="dropdown">

              <img
                src="<%= locals.user.profileImageURL || '/images/avatar-placeholder.png' %>"
                class="user-avatar me-2"
              />

              <span><%= locals.user.fullName %></span>
            </a>

            <ul class="dropdown-menu dropdown-menu-end custom-dropdown" aria-labelledby="userMenu">
              <li><a class="dropdown-item" href="/user/profile">Profile</a></li>
              <li><a class="dropdown-item" href="/user/settings">Settings</a></li>
              <li><hr class="dropdown-divider"></li>
              <li><a class="dropdown-item text-danger" href="/user/logout">Log out</a></li>
            </ul>
          </li>

        <% } else { %>

          <li class="nav-item">
            <a class="nav-link custom-link" href="/user/signup">Create Account</a>
          </li>

          <li class="nav-item">
            <a class="nav-link custom-link" href="/user/signin">Sign in</a>
          </li>

        <% } %>

      </ul>
    </div>

  </div>
</nav>
